# Soterra AI — local secrets template.
# Copy to .env and fill in real values. .env is gitignored; this file is committed.
# Cron uses GitHub Actions secrets of the same names.

# GCP Cloud Billing API key — required for fetch_gcp_pricing.
# Create at https://console.cloud.google.com/apis/credentials
# Enable "Cloud Billing API" in the same project before creating the key.
GCP_API_KEY=
