<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% block title %}Soterra Labs{% endblock %}</title>
  <meta name="description" content="{% block description %}Soterra Labs.{% endblock %}" />
  <link rel="canonical" href="{% block canonical %}https://soterralabs.ai/{% endblock %}" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  {# Open Graph + Twitter Card — strong SEO signal for shares + crawlers #}
  <meta property="og:type" content="{% block og_type %}website{% endblock %}" />
  <meta property="og:title" content="{% block og_title %}{{ self.title() }}{% endblock %}" />
  <meta property="og:description" content="{% block og_description %}{{ self.description() }}{% endblock %}" />
  <meta property="og:url" content="{{ self.canonical() }}" />
  <meta property="og:site_name" content="Soterra Labs" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ self.og_title() }}" />
  <meta name="twitter:description" content="{{ self.og_description() }}" />

  {# Schema.org — Organization once site-wide, page-specific structured data per template #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Soterra Labs",
    "legalName": "Soterra Labs LLC",
    "url": "https://soterralabs.ai",
    "logo": "https://soterralabs.ai/logo-lit-circle.svg"
  }
  </script>
  {% block extra_schema %}{% endblock %}

  {%- block style_link %}{% endblock %}
</head>
<body{% if body_class %} class="{{ body_class }}"{% endif %}{% if active_nav %} data-active-nav="{{ active_nav }}"{% endif %}>

  <nav class="site-nav">
    <div class="nav-inner">
      <a href="/" class="logo" aria-label="Soterra Labs home">
        <img src="/logo-lit-circle.svg" alt="Soterra Labs" />
      </a>
      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links" id="navLinks">
        <li><a href="/#services">Services</a></li>
        <li><a href="/products">Products</a></li>
        {%- if section == "anvil" %}
        <li class="has-children">
          <a href="/anvil/" {% if active_nav == 'reference' %}class="active"{% endif %}>Reference</a>
          <ul class="dropdown">
            <li><a href="/anvil/pricing">&middot; Cloud GPU Pricing</a></li>
            {%- if mlperf_ready %}
            <li><a href="/anvil/mlperf">&middot; MLPerf Inference Results</a></li>
            {%- endif %}
          </ul>
        </li>
        {%- endif %}
        <li><a href="/#thinking">Thinking</a></li>
        <li><a href="/#about">About</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
    </div>
  </nav>
  <script>
    (function() {
      var toggle = document.getElementById('navToggle');
      var links = document.getElementById('navLinks');
      if (!toggle || !links) return;
      toggle.addEventListener('click', function() {
        var open = links.classList.toggle('open');
        toggle.classList.toggle('open', open);
        toggle.setAttribute('aria-expanded', open);
      });
      links.querySelectorAll('a').forEach(function(a) {
        a.addEventListener('click', function() {
          links.classList.remove('open');
          toggle.classList.remove('open');
          toggle.setAttribute('aria-expanded', 'false');
        });
      });
    })();
    // Live relative-time. Server bakes "Just now" / "53 minutes ago" at
    // build time; that string goes stale between cron runs AND when a
    // visitor leaves the tab open for hours after JS first ran. Fix:
    // (1) re-run on a 60s interval, (2) re-run when the tab becomes
    // visible again (catches "left open overnight" case).
    // Python writes 6-digit microseconds (.123456); some browsers
    // truncate, some don't — normalize to milliseconds before parsing
    // for cross-browser safety.
    (function() {
      function parseIso(s) {
        if (!s) return null;
        var clean = s.replace(/\.(\d{3})\d+(?=[+\-Z])/, '.$1');
        var d = new Date(clean);
        return isNaN(d.getTime()) ? null : d;
      }
      function relativeFrom(then, now) {
        var diffSec = Math.max(0, (now.getTime() - then.getTime()) / 1000);
        if (diffSec < 60) return 'Just now';
        var m = Math.floor(diffSec / 60);
        if (m === 1) return '1 minute ago';
        if (m < 60) return m + ' minutes ago';
        var h = Math.floor(m / 60);
        if (h === 1) return '1 hour ago';
        if (h < 24) return h + ' hours ago';
        var d = Math.floor(h / 24);
        if (d === 1) return '1 day ago';
        if (d < 7) return d + ' days ago';
        var w = Math.floor(d / 7);
        if (w === 1) return '1 week ago';
        if (w < 5) return w + ' weeks ago';
        var mo = Math.floor(d / 30);
        if (mo === 1) return '1 month ago';
        return mo + ' months ago';
      }
      function refresh() {
        var now = new Date();
        document.querySelectorAll('[data-iso]').forEach(function(el) {
          var then = parseIso(el.getAttribute('data-iso'));
          if (then) el.textContent = relativeFrom(then, now);
        });
      }
      // The shim runs at the TOP of <body>, before <main> is parsed —
      // so [data-iso] elements don't exist in the DOM yet. Defer the
      // initial refresh() until DOMContentLoaded fires (or run
      // immediately if the document is already complete, which happens
      // when the script is appended dynamically). Without this the
      // first refresh hits an empty NodeList; setInterval would
      // self-correct after 60s but the user sees the build-time bake-in
      // for that window — which is the bug Sri caught 2026-04-29.
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', refresh);
      } else {
        refresh();
      }
      setInterval(refresh, 60000);
      document.addEventListener('visibilitychange', function() {
        if (!document.hidden) refresh();
      });
    })();
  </script>

  <main>
    {% block content %}{% endblock %}
  </main>

  <footer class="site-footer">
    <p>&copy; 2026 <span>Soterra Labs</span> &mdash; {% include "_brand_slogan.html.j2" %}<span class="footer-sep">&middot;</span><a href="/legal/" class="footer-link">Legal</a></p>
  </footer>

</body>
</html>
