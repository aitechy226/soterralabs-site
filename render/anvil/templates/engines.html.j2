{% extends "base.html.j2" %}

{% block title %}LLM Inference Engine Facts — Soterra Labs Anvil{% endblock %}
{% block description %}Side-by-side reference of nine open-source LLM inference engines (vLLM, Ollama, TGI, llama.cpp, MLC-LLM, TensorRT-LLM, SGLang, LMDeploy, DeepSpeed-MII) on project health, container, API routes, and observability. Every cell links to its SHA-pinned source.{% endblock %}
{% block canonical %}https://soterralabs.ai/anvil/engines{% endblock %}
{% block og_type %}article{% endblock %}

{% block extra_schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": "LLM Inference Engine Facts",
  "description": "Side-by-side literal evidence on nine open-source LLM inference engines.",
  "url": "https://soterralabs.ai/anvil/engines",
  "dateModified": "{{ engines.extracted_at_iso }}",
  "publisher": {"@type": "Organization", "name": "Soterra Labs"}
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "LLM Inference Engine Facts — Soterra Labs Anvil",
  "description": "Side-by-side reference of nine open-source LLM inference engines (vLLM, Ollama, TGI, llama.cpp, MLC-LLM, TensorRT-LLM, SGLang, LMDeploy, DeepSpeed-MII), covering project health, container packaging, API routes, and observability. Every value is extracted from public source code or published container images and pinned to a commit SHA. Rebuilt weekly.",
  "url": "https://soterralabs.ai/anvil/engines",
  "creator": {"@type": "Organization", "name": "Soterra Labs"},
  "license": "https://soterralabs.ai/legal/",
  "isAccessibleForFree": true,
  "dateModified": "{{ engines.extracted_at_iso }}",
  "keywords": "LLM inference engine, vLLM, Ollama, TGI, llama.cpp, MLC-LLM, TensorRT-LLM, SGLang, LMDeploy, DeepSpeed-MII, Prometheus exporter, OpenAI-compatible API, CUDA, ROCm"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://soterralabs.ai/"},
    {"@type": "ListItem", "position": 2, "name": "Reference", "item": "https://soterralabs.ai/anvil/"},
    {"@type": "ListItem", "position": 3, "name": "Engine Facts", "item": "https://soterralabs.ai/anvil/engines"}
  ]
}
</script>
{% endblock %}

{% block content %}

<div class="page-header">
  <div class="page-header-inner">
    <div class="eyebrow">Soterra Labs Anvil &middot; Engine Facts</div>
    <h1>LLM Inference Engine Facts</h1>
    <p class="lead">
      Nine open-source LLM inference engines, side-by-side, on the surface area buyers actually evaluate: project health, container, API routes, observability. Every cell is literal evidence pulled from each project's repo and published image &mdash; not benchmark scores, not vendor claims.
    </p>
    {% if not engines.is_stale %}
    <p class="freshness">
      Last refreshed: <time datetime="{{ engines.extracted_at_iso }}">{{ engines.extracted_at_display }}</time>
      <span class="muted">(<span data-iso="{{ engines.extracted_at_iso }}">{{ engines.extracted_at_relative }}</span>)</span>
    </p>
    {% endif %}
  </div>
</div>

<div class="body-section">

  {% if engines.is_stale %}
  <div class="banner-stale">
    <strong>Engine facts are stale.</strong> Last refreshed <time datetime="{{ engines.extracted_at_iso }}">{{ engines.extracted_at_display }}</time> &mdash; older than the 14-day cadence (weekly cron + one missed cycle of grace). A fix is in progress; in the meantime, click any cell to open the SHA-pinned source on GitHub for the freshest values.
  </div>
  {% endif %}

  <div class="info-card">
    <h3>How to read this page</h3>
    <ul>
      <li><strong>Four categories.</strong> Project Meta (is it maintained?), Container (can I pull it?), API Surface (does it speak my client's protocol?), Observability (can I run it in production?).</li>
      <li><strong>Every cell is literal.</strong> A populated value means we found the string, route, or file in source. A "&mdash;" means we didn't &mdash; and the caption underneath says why.</li>
      <li><strong>Empty-cell vocabulary.</strong> <em>not applicable</em> (categorically out of scope), <em>not declared</em> (the project's source files don't declare it), <em>not detected</em> (our probe didn't find it; it may exist elsewhere), <em>unsupported runtime</em> (Dockerfile points at a plain-OS base, no GPU runtime).</li>
      <li><strong>Sort order is editorial.</strong> The default order is alphabetical. Columns are not ranked; rows are not ranked.</li>
      <li><strong>Audit trail.</strong> Every cell links to the file, line, and commit SHA we read it from.</li>
      <li><strong>Rebuilt weekly.</strong> The next refresh runs every Monday at 06:00 UTC.</li>
      <li><strong>Where to start.</strong> If you're filtering for a specific protocol, jump to API Surface. If you're filtering for ops-readiness, jump to Observability.</li>
    </ul>
  </div>

  {% if engines.fact_groups %}
  <nav class="anchor-nav engines-nav" aria-label="Jump to category">
    <span class="label">Jump to:</span>
    {% for group in engines.fact_groups %}
    <a href="#{{ group.category }}">{{ group.category_label }}</a>
    {% endfor %}
  </nav>

  <p class="scroll-hint">Scroll table sideways to see all columns &rarr;</p>

  {% for group in engines.fact_groups %}
  <section class="engine-facts-section" id="{{ group.category }}">
    <header class="engine-facts-section-header">
      <h2>{{ group.category_label }}</h2>
      <p class="category-definition">{{ group.category_definition }}</p>
    </header>
    <div class="table-scroll">
      <table class="engines-table">
        <thead>
          <tr>
            <th class="engine-col">Engine</th>
            {% for row in group.rows %}
            <th>
              <span class="fact-type-label">{{ row.fact_type_label }}</span>
              <span class="fact-type-definition">{{ row.fact_type_definition }}</span>
            </th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for engine_idx in range(engines.engines | length) %}
          {% set col = engines.engines[engine_idx] %}
          <tr{% if col.is_engine_stale %} class="row-stale"{% endif %}>
            <th class="engine-col" scope="row">
              <a href="{{ col.repo_url }}" rel="nofollow noopener">{{ col.display_name }}</a>
              {% if col.extraction_failed_badge %}
              <span class="extraction-failed-badge" aria-label="{{ col.extraction_failed_aria }}" title="{{ col.extraction_failed_aria }}">{{ col.extraction_failed_badge }}</span>
              {% endif %}
            </th>
            {% for row in group.rows %}
            {% set cell = row.cells[engine_idx] %}
            <td class="{{ cell.cell_state_class }}{% if cell.is_engine_stale %} cell-stale{% endif %}">
              {% if cell.fact_value %}
              <a href="{{ cell.evidence_url }}" class="cell-evidence-link" rel="nofollow noopener">{{ cell.display_value }}</a>
              {% else %}
              <a href="{{ cell.evidence_url }}" class="cell-evidence-link em-dash" rel="nofollow noopener">{{ cell.display_value }}</a>
              {% if cell.note %}<span class="cell-note">{{ cell.note }}</span>{% endif %}
              {% endif %}
            </td>
            {% endfor %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endfor %}
  {% else %}
  <p class="caveat">
    <strong>No engine facts available.</strong> The first extraction run has not completed yet, or the extractor pipeline is currently failing. Check back soon.
  </p>
  {% endif %}

  <footer class="methodology">
    <h2>How this page is built</h2>
    <p>
      Rebuilt weekly from each project's GitHub repository and its published container image (Docker Hub, GHCR, or NGC, whichever the project publishes to). No human edits values on this page. Every cell is pinned to the file path, line number, and commit SHA we read it from &mdash; the audit-trail link in each cell opens the source. New evidence appears the Monday after each project's update; structural changes (new fact_types, new engines) ship after a one-time review by Soterra Labs.
    </p>
    <p class="footer-disclaimer">
      vLLM, Ollama, Text Generation Inference, llama.cpp, MLC-LLM, TensorRT-LLM, SGLang, LMDeploy, and DeepSpeed-MII are projects of their respective maintainers. NVIDIA, AMD, Hugging Face, Microsoft, Docker, GitHub, and the sgl-project organization are trademarks of their respective owners. NGC and GHCR are registry services of NVIDIA Corporation and GitHub respectively. Soterra Labs is not affiliated with, endorsed by, or sponsored by any of the above. Evidence is reproduced from public source repositories and public container registries. See <a href="/legal/" target="_blank" rel="noopener">Terms</a>.
    </p>
  </footer>

  <div class="soterra-attribution">
    <strong>Soterra Labs</strong> &mdash; From GPU to Revenue<sup style="font-size:0.6em; vertical-align:super;">&trade;</sup> &middot; <a href="/products">Products</a> &middot; <a href="/thinking/">Thinking</a>
  </div>

</div>

{% endblock %}
