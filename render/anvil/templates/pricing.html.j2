{% extends "base.html.j2" %}

{% block title %}Live Cloud GPU Pricing — Soterra Labs Anvil{% endblock %}
{% block description %}Current list-price hourly rates for GPU instances on AWS, Azure, and GCP. Refreshed daily. Every cell traces to the cloud's own pricing API.{% endblock %}
{% block canonical %}https://soterralabs.ai/anvil/pricing{% endblock %}
{% block og_type %}article{% endblock %}

{% block extra_schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": "Live Cloud GPU Pricing",
  "description": "Current list-price hourly rates for GPU instances on AWS, Azure, and GCP, refreshed daily.",
  "url": "https://soterralabs.ai/anvil/pricing",
  "dateModified": "{{ pricing.latest_fetch_iso }}",
  "publisher": {"@type": "Organization", "name": "Soterra Labs"}
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "Cloud GPU On-Demand Pricing",
  "description": "Daily snapshot of public list-price hourly rates for GPU instances across AWS, Azure, and GCP.",
  "url": "https://soterralabs.ai/anvil/pricing",
  "creator": {"@type": "Organization", "name": "Soterra Labs"},
  "license": "https://soterralabs.ai/legal/",
  "isAccessibleForFree": true,
  "dateModified": "{{ pricing.latest_fetch_iso }}",
  "keywords": "GPU pricing, cloud GPU, AWS GPU pricing, Azure GPU pricing, GCP GPU pricing, H100, H200, B200, MI300X"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://soterralabs.ai/"},
    {"@type": "ListItem", "position": 2, "name": "Reference", "item": "https://soterralabs.ai/anvil/"},
    {"@type": "ListItem", "position": 3, "name": "Cloud GPU Pricing", "item": "https://soterralabs.ai/anvil/pricing"}
  ]
}
</script>
{% endblock %}

{% block content %}

<div class="page-header">
  <div class="page-header-inner">
    <div class="eyebrow">Soterra Labs Anvil &middot; Live Pricing</div>
    <h1>Cloud GPU Pricing</h1>
    <p class="lead">
      Current list-price hourly rates for GPU instances on AWS, Azure, and GCP, refreshed daily. Every cell traces back to the cloud's own pricing API.
    </p>
    {% if not pricing.is_stale %}
    <p class="freshness">
      Last refreshed: <time datetime="{{ pricing.latest_fetch_iso }}">{{ pricing.latest_fetch_display }}</time>
      <span class="muted">(<span data-iso="{{ pricing.latest_fetch_iso }}">{{ pricing.relative_age_display }}</span>)</span>
    </p>
    {% endif %}
  </div>
</div>

<div class="body-section">

  {% if pricing.is_stale %}
  <div class="banner-stale">
    <strong>Pricing data is stale.</strong> Last refreshed <time datetime="{{ pricing.latest_fetch_iso }}">{{ pricing.latest_fetch_display }}</time> &mdash; older than the 36-hour refresh cadence. A fix is in progress; in the meantime, verify any cell against the cloud's own pricing portal before relying on it.
  </div>
  {% endif %}

  <p class="caveat">
    <strong>List on-demand prices only.</strong> Reserved instances, committed-use agreements, and negotiated enterprise contracts are typically priced lower &mdash; verify with your cloud account team. Spot prices are not shown.
  </p>

  {% if pricing.gpu_groups %}
  <nav class="anchor-nav" aria-label="Jump to GPU class">
    <span class="label">Jump to:</span>
    {% for group in pricing.gpu_groups %}
    <a href="#{{ group.anchor_id }}">{{ group.display_name | replace("NVIDIA ", "") | replace("AMD Instinct ", "") | replace("Intel ", "") }}</a>
    {% endfor %}
  </nav>

  <p class="scroll-hint">Scroll table sideways to see all columns &rarr;</p>

  <div class="table-scroll">
    <table class="pricing-table">
      <thead>
        <tr>
          <th>GPU Type</th>
          <th>Cloud</th>
          <th>Region</th>
          <th>Instance Type</th>
          <th class="num"># GPUs</th>
          <th class="num">$/hr</th>
          <th class="num">$/GPU/hr</th>
        </tr>
      </thead>
      <tbody>
        {% for group in pricing.gpu_groups %}
        {% set group_shade_class = 'gpu-group-shaded' if loop.index0 % 2 == 1 else '' %}
        {% for q in group.quotes %}
        <tr class="{{ group_shade_class }}{% if loop.first %} gpu-group-start{% endif %}"{% if loop.first %} id="{{ group.anchor_id }}"{% endif %}>
          <td class="gpu-cell">{{ group.display_name }}</td>
          <td><span class="cloud-tag">{{ q.cloud_display }}</span></td>
          <td>{{ q.region }}</td>
          <td>{{ q.instance_type }}</td>
          <td class="num">{{ q.gpu_count }}</td>
          <td class="num">${{ "%.2f"|format(q.price_per_hour_usd) }}</td>
          <td class="num">${{ "%.2f"|format(q.price_per_gpu_per_hour_usd) }}</td>
        </tr>
        {% endfor %}
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <p class="caveat">
    <strong>No pricing data available.</strong> The first fetch has not completed yet, or all fetchers are currently failing. Check back soon.
  </p>
  {% endif %}

  <footer class="methodology">
    <h2>How this page is built</h2>
    <p>
      Rebuilt daily from the public pricing APIs of AWS, Azure, and GCP. No human edits prices on this page. The only manual step &mdash; adding a new instance type when a cloud announces one &mdash; happens as clouds release new SKUs and is recorded in a public mapping file.{% if mlperf_ready %} For benchmark performance data, see <a href="/anvil/mlperf">our MLPerf results browser</a>.{% endif %}
    </p>
    <p class="footer-disclaimer">
      List prices fetched from public AWS, Azure, and GCP pricing catalogs. Verify against your vendor portal before contracting. Soterra Labs has no commercial relationship with AWS, Azure, GCP, NVIDIA, AMD, or Intel; data is fetched from public APIs only. Soterra Labs does not warrant the accuracy of these values; see <a href="/legal/">Terms</a>.
    </p>
  </footer>

  <div class="soterra-attribution">
    <strong>Soterra Labs</strong> &mdash; From GPU to Revenue<sup style="font-size:0.6em; vertical-align:super;">&trade;</sup> &middot; <a href="/products">Products</a> &middot; <a href="/thinking/">Thinking</a>
  </div>

</div>

{% endblock %}
