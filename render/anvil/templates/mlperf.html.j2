{% extends "base.html.j2" %}

{% block title %}MLPerf Inference Results — Soterra Labs Anvil{% endblock %}
{% block description %}Latest MLPerf Inference Datacenter results, filtered to common workloads. Every row links to its official MLCommons submission.{% endblock %}
{% block canonical %}https://soterralabs.ai/anvil/mlperf{% endblock %}
{% block og_type %}article{% endblock %}

{% block extra_schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": "MLPerf Inference Results",
  "description": "Latest schema-audited MLPerf Inference Datacenter results, filtered to common workloads.",
  "url": "https://soterralabs.ai/anvil/mlperf",
  "dateModified": "{{ mlperf.fetched_at_iso }}",
  "publisher": {"@type": "Organization", "name": "Soterra Labs"}
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "MLPerf Inference Results — Soterra Labs Anvil",
  "description": "Weekly snapshot of public MLPerf Inference Datacenter submission results.",
  "url": "https://soterralabs.ai/anvil/mlperf",
  "creator": {"@type": "Organization", "name": "Soterra Labs"},
  "license": "https://soterralabs.ai/legal/",
  "isAccessibleForFree": true,
  "dateModified": "{{ mlperf.fetched_at_iso }}",
  "keywords": "MLPerf, MLPerf Inference, MLCommons benchmarks, llama2, mixtral, stable diffusion, BERT, gpt-j, H100, H200, B200, MI300X"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://soterralabs.ai/"},
    {"@type": "ListItem", "position": 2, "name": "Reference", "item": "https://soterralabs.ai/anvil/"},
    {"@type": "ListItem", "position": 3, "name": "MLPerf Inference Results", "item": "https://soterralabs.ai/anvil/mlperf"}
  ]
}
</script>
{% endblock %}

{% block content %}

<div class="page-header">
  <div class="page-header-inner">
    <div class="eyebrow">Soterra Labs Anvil &middot; MLPerf Results</div>
    <h1>MLPerf Inference Results <span class="round-tag">Round {{ mlperf.latest_round }}</span></h1>
    <p class="lead">
      Published MLPerf Inference Datacenter results for common workloads, sourced from MLCommons. Every row links to the official submission detail page.
    </p>
    <p class="round-published">
      Round published: <time datetime="{{ mlperf.round_published_at_iso }}">{{ mlperf.round_published_at_display }}</time>
    </p>
    {% if not mlperf.is_round_stale %}
    <p class="freshness">
      Ingested: <time datetime="{{ mlperf.fetched_at_iso }}">{{ mlperf.fetched_at_display }}</time>
      <span class="muted">({{ mlperf.relative_age_display }})</span>
    </p>
    {% endif %}
  </div>
</div>

<div class="body-section">

  {% if mlperf.is_round_stale %}
  <div class="banner-stale">
    <strong>This round may not be current.</strong> The latest tracked MLPerf round is from <time datetime="{{ mlperf.round_published_at_iso }}">{{ mlperf.round_published_at_display }}</time>. New rounds typically publish every six months; if a newer round has been released, schema verification is in progress before it appears here.
  </div>
  {% endif %}

  <p class="caveat">
    <strong>About these numbers.</strong> MLPerf submissions are tuned by vendors for the benchmark and run on highly optimized configurations &mdash; specific batch sizes, quantization choices, and serving stacks selected to maximize the metric. Production workloads with different traffic patterns, accuracy requirements, or stack constraints will measure differently. Use these results to compare systems against each other on a common task, not to size capacity for your own deployment.
  </p>

  <div class="info-card">
    <h3>How to read these tables</h3>
    <ul>
      <li><strong>Workloads</strong> &mdash;
        <strong>llama2-70b-99</strong> (Meta Llama 2 70B chat),
        <strong>llama3.1-405b</strong> (Meta Llama 3.1 405B &mdash; the largest tracked model),
        <strong>mixtral-8x7b</strong> (Mistral Mixtral mixture-of-experts),
        <strong>stable-diffusion-xl</strong> (text-to-image),
        <strong>bert-99</strong> (BERT-Large encoder for text classification),
        <strong>gptj-99</strong> (GPT-J 6B text generation).
        The <strong>-99</strong> / <strong>-99.9</strong> suffix is the accuracy track (see below).
      </li>
      <li><strong>Server vs Offline</strong> &mdash; MLPerf's two scenario types. <strong>Server</strong> simulates real-time traffic with per-query latency limits (the system has to keep up with arriving requests). <strong>Offline</strong> is batch processing with no latency constraint &mdash; pure peak throughput. The same hardware will score differently on each.</li>
      <li><strong>Stack</strong> &mdash; topology + memory layout the submitter used (e.g. <code>8x H200-SXM-141GB</code>, <code>4x8x MI300X-192GB</code>). Useful for spotting multi-node clusters and HBM variants; redundant with the GPU + #Accelerators columns for single-node submissions.</li>
      <li><strong>Engine</strong> &mdash; the inference / serving software (TensorRT-LLM, vLLM, LLMBoost, etc.). Throughput often differs more between engines than between hardware variants of the same chip — a top result on LLMBoost or a vendor-internal stack means the buyer would need that same stack to reproduce. Pulled from MLCommons' Software field; version numbers stripped.</li>
      <li><strong># Accelerators</strong> &mdash; total GPU/AI chips the submission used (per-node count &times; nodes). All throughput metrics below are for the whole system, not per chip.</li>
      <li><strong>Tokens/s, Samples/s, Queries/s</strong> &mdash; total system throughput. Higher is faster. Different workloads use different units (LLMs report tokens/s; image generation reports samples/s; classifiers report queries/s).</li>
      <li><strong>Accuracy: 99.0% vs 99.9%</strong> &mdash; MLPerf's two accuracy tiers per workload. Both mean the submission cleared a quality bar relative to a reference baseline; <strong>99.9%</strong> is the stricter "very-high-accuracy" track. This is <em>not</em> the model's absolute accuracy &mdash; it's which accuracy track the submitter chose.</li>
    </ul>
  </div>

  {% if mlperf.workloads %}
  <nav class="anchor-nav workloads" aria-label="Jump to workload">
    <span class="label">Jump to:</span>
    {% for w in mlperf.workloads %}
    <a href="#{{ w.anchor_id }}">{{ w.display_label }}</a>
    {% endfor %}
  </nav>

  <p class="scroll-hint">Scroll table sideways to see all columns &rarr;</p>

  {% for w in mlperf.workloads %}
  <details class="workload" id="{{ w.anchor_id }}"{% if w.is_open_by_default %} open{% endif %}>
    <summary>
      <span class="wl-name">{{ w.display_label }}</span>
      <span class="wl-meta">{{ w.submission_count }} submissions <span class="top">&middot; {{ w.top_result_display }}</span></span>
    </summary>
    <div class="wl-body">
      <div class="table-scroll">
        <table class="mlperf-table">
          <thead>
            <tr>
              <th>GPU</th>
              <th>Submitter</th>
              <th>System</th>
              <th>Stack</th>
              <th>Engine</th>
              <th class="num"># Accelerators</th>
              <th class="num">{{ w.metric_unit_display }}</th>
              <th class="num">Accuracy</th>
              <th>Submission</th>
            </tr>
          </thead>
          <tbody>
            {% for r in w.results %}
            <tr{% if r.band %} class="gpu-band"{% endif %}>
              <td class="gpu-cell">{{ r.display_gpu }}</td>
              <td>{{ r.submitter }}</td>
              <td>{{ r.system_name }}</td>
              <td class="stack-cell">{{ r.stack }}</td>
              <td class="engine-cell">{{ r.engine }}</td>
              <td class="num">{{ r.accelerator_count }}</td>
              <td class="num">{{ "{:,.1f}".format(r.metric_value) }}</td>
              <td class="num">{{ r.accuracy }}</td>
              <td>{% if r.submission_url %}<a href="{{ r.submission_url }}" class="submission-link" rel="nofollow noopener">[link]</a>{% else %}&mdash;{% endif %}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </details>
  {% endfor %}
  {% else %}
  <p class="caveat">
    <strong>No MLPerf data available.</strong> The first ingest has not completed yet, or the latest round has not been schema-audited.
  </p>
  {% endif %}

  <footer class="methodology">
    <h2>How this page is built</h2>
    <p>
      Rebuilt weekly from MLCommons-published CSVs. No human edits results on this page. New rounds appear after a one-time schema check by Soterra Labs to confirm the source columns have not changed; this typically takes a few days after MLCommons publishes. For current cloud GPU pricing, see <a href="/anvil/pricing">our pricing tracker</a>.
    </p>
    <p class="footer-disclaimer">
      MLPerf and MLCommons are trademarks of MLCommons. Soterra Labs is not affiliated with MLCommons. Results are reproduced from public MLCommons publications; refer to the linked submission pages for full system configuration. Soterra Labs has no commercial relationship with NVIDIA, AMD, Intel, or any submitter shown. See <a href="/legal/" target="_blank" rel="noopener">Terms</a>.
    </p>
  </footer>

  <div class="soterra-attribution">
    Built and maintained by <strong>Soterra Labs</strong> &mdash; From GPU to Revenue<sup style="font-size:0.6em; vertical-align:super;">&trade;</sup>. We help vendors and enterprises make defensible GPU infrastructure decisions. See our <a href="/products">products</a> or <a href="/thinking/">recent thinking</a>.
  </div>

</div>

{% endblock %}
