{% extends "base.html.j2" %}

{% block title %}Reference — Soterra Labs Anvil{% endblock %}
{% block description %}Free public reference data for AI infrastructure decisions: live cloud GPU pricing and MLPerf inference results, refreshed automatically.{% endblock %}
{% block canonical %}https://soterralabs.ai/anvil/{% endblock %}

{% block extra_schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://soterralabs.ai/"},
    {"@type": "ListItem", "position": 2, "name": "Reference", "item": "https://soterralabs.ai/anvil/"}
  ]
}
</script>
{% endblock %}

{% block content %}

<div class="page-header">
  <div class="page-header-inner">
    <div class="eyebrow">Soterra Labs Anvil</div>
    <h1>Reference data for <span class="accent-word">AI infrastructure</span> decisions.</h1>
    <p class="lead">
      Free public reference content, refreshed automatically from public APIs and benchmark publications. Every value on every page traces back to its source. No editorial commentary, no human-edited numbers.
    </p>
  </div>
</div>

<div class="body-section">

  <div class="reports-grid">
    {% for card in landing.cards %}
    <article class="report-card{% if not card.is_ready %} coming-soon{% endif %}">
      <div class="card-eyebrow">{{ card.eyebrow }}</div>
      <h2>{{ card.title }}</h2>
      <p class="description">{{ card.description }}</p>
      <div class="freshness-pill">
        <span><strong>{{ card.freshness_main }}{% if card.freshness_iso and card.freshness_main_relative %}<span data-iso="{{ card.freshness_iso }}">{{ card.freshness_main_relative }}</span>{% endif %}</strong>{% if card.freshness_muted or card.freshness_muted_relative %} <span class="muted">{{ card.freshness_muted }}{% if card.freshness_iso and card.freshness_muted_relative %}<span data-iso="{{ card.freshness_iso }}">{{ card.freshness_muted_relative }}</span>{% endif %}</span>{% endif %}</span>
      </div>
      {% if card.is_ready %}
      <a href="{{ card.url }}" class="report-cta">{{ card.cta_label }}</a>
      {% else %}
      <span class="report-cta">{{ card.cta_label }}</span>
      {% endif %}
    </article>
    {% endfor %}
  </div>

  <div class="methodology-block">
    <h2>How Anvil works</h2>
    <p>
      Each Anvil page is rebuilt on a fixed cadence by a fully automated pipeline: scheduled fetcher pulls public data, validates plausibility against bounded ranges, commits to an audit-traceable database, and rebuilds the page. No human edits values; humans only update name-mapping configuration when a new instance type or accelerator appears in upstream sources. When a fetch fails, the previous good page stays live and a banner indicates the data is stale.
    </p>
  </div>

  <div class="soterra-attribution">
    <strong>Soterra Labs</strong> &mdash; From GPU to Revenue<sup style="font-size:0.6em; vertical-align:super;">&trade;</sup> &middot; <a href="/products">Products</a> &middot; <a href="/thinking/">Thinking</a>
  </div>

</div>

{% endblock %}
